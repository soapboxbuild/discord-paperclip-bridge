# Paperclip API credentials
# PAPERCLIP_API_KEY: Run `POST /api/agents/<your-agent-id>/keys` via the Paperclip UI or API
PAPERCLIP_API_URL=https://org.soapbox.build
PAPERCLIP_API_KEY=your-paperclip-api-key-here
PAPERCLIP_COMPANY_ID=bca4541f-fc58-48ce-84f0-7fa71df7c67c

# ── Sophie's gateway bot (handles #sophie-ceo, DMs, and #board-approvals) ───
DISCORD_BOT_TOKEN_SOPHIE=your-sophie-bot-token

# ── Per-agent channel bots (SOA-372) ────────────────────────────────────────
# Each agent connects with their own token, appearing as themselves in their channel.
# These tokens are for GUILD CHANNEL listening only (not DMs).
# Note: ANGIE_BOT_TOKEN and DISCORD_BOT_TOKEN_ANGIE may be the same token or different:
#   - Same token → the bot connects twice (channel + DM). Discord allows this; DMs process once
#     because the channel BridgeBot ignores DMs (isDM check) and the DM BridgeBot ignores channels.
#   - Different tokens → two distinct Discord bots per agent (channel bot + DM bot).
#     Unusual but valid if you want separate Discord app identities.
ANGIE_BOT_TOKEN=your-angie-bot-token
EARL_BOT_TOKEN=your-earl-bot-token
PARADH_BOT_TOKEN=your-paradh-bot-token

# Channel IDs (defaults hardcoded; override if your Discord server differs)
# SOPHIE_CHANNEL_ID=1516986529162072208
# ANGIE_CHANNEL_ID=1517300227357409300
# EARL_CHANNEL_ID=1516986742035447829
# PARADH_CHANNEL_ID=1517300899389903089
# BOARD_APPROVALS_CHANNEL_ID=1516994726320930836

# Agent IDs (defaults hardcoded; do not change unless you know what you're doing)
# SOPHIE_AGENT_ID=573ff2a4-0623-4fcd-ac8e-51d7b11d29c8
# ANGIE_AGENT_ID=2d259ea5-9446-4c5e-911d-bbe03ec532db
# EARL_AGENT_ID=97d41ad6-1ece-4870-92cb-0ae121c2eeb8
# PARADH_AGENT_ID=defdd30b-a5cc-42db-82c2-0c39571e350a

# Board-level Paperclip API key for approval resolution (falls back to PAPERCLIP_API_KEY)
# PAPERCLIP_BOARD_API_KEY=your-board-api-key

# ── Per-agent DM bots (SOA-156) ──────────────────────────────────────────────────
# Set any of these to give that agent their own Discord bot for direct DMs.
# Each runs alongside the gateway listener. Sophie is excluded (her DMs use the gateway).
# These vars are separate from ANGIE_BOT_TOKEN etc. — see note above on same vs different token.
# DISCORD_BOT_TOKEN_ANGIE=your-angie-bot-token
# DISCORD_BOT_TOKEN_SAKKA=your-sakka-bot-token
# DISCORD_BOT_TOKEN_EARL=your-earl-bot-token
# DISCORD_BOT_TOKEN_FINN=your-finn-bot-token
# DISCORD_BOT_TOKEN_MIKE=your-mike-bot-token
# DISCORD_BOT_TOKEN_DESI=your-desi-bot-token
# DISCORD_BOT_TOKEN_ARI=your-ari-bot-token
# DISCORD_BOT_TOKEN_DEVI=your-devi-bot-token
# DISCORD_BOT_TOKEN_MONET=your-monet-bot-token
# DISCORD_BOT_TOKEN_PARADH=your-paradh-bot-token
# DISCORD_BOT_TOKEN_LEON=your-leon-bot-token
# DISCORD_BOT_TOKEN_VERA=your-vera-bot-token

# ── Legacy per-bot approach (only used when DISCORD_BOT_TOKEN_SOPHIE is absent) ──
# SOPHIE_DISCORD_TOKEN=your-sophie-bot-token
# SOPHIE_CHANNEL_ID=your-sophie-channel-id
# BOARD_DISCORD_TOKEN=your-board-bot-token

# ── Haiku conversational tier (SOA-349) ──────────────────────────────────────
# Required: enables fast Haiku responses instead of full Paperclip agent runs
ANTHROPIC_API_KEY=your-anthropic-api-key
# Optional: add Hindsight context to Haiku responses (from Vaultwarden: 'Hindsight Memory (Railway)')
# HINDSIGHT_API_KEY=your-hindsight-api-key

# Optional tuning
CONVERSATION_EXPIRY_MINUTES=30
POLL_INTERVAL_SECONDS=5
POLL_TIMEOUT_SECONDS=300
