# Paperclip API credentials
# PAPERCLIP_API_KEY: Run `POST /api/agents/<your-agent-id>/keys` via the Paperclip UI or API
PAPERCLIP_API_URL=https://org.soapbox.build
PAPERCLIP_API_KEY=your-paperclip-api-key-here
PAPERCLIP_COMPANY_ID=bca4541f-fc58-48ce-84f0-7fa71df7c67c

# Sophie's Discord bot (token from Vaultwarden: "Discord Bot - Sophie")
SOPHIE_DISCORD_TOKEN=your-sophie-bot-token
# Sophie's dedicated Discord channel ID (right-click channel → Copy Channel ID)
SOPHIE_CHANNEL_ID=your-sophie-channel-id
# Sophie's Paperclip agent ID (pre-configured, do not change)
SOPHIE_AGENT_ID=573ff2a4-0623-4fcd-ac8e-51d7b11d29c8

# Board Approvals bot — handles approve/reject from Discord (optional)
# Same token as Sophie's bot or a dedicated board bot token
BOARD_DISCORD_TOKEN=your-board-bot-token
# Channel ID for #board-approvals
BOARD_APPROVALS_CHANNEL_ID=your-board-approvals-channel-id
# Board-level Paperclip API key (if separate from PAPERCLIP_API_KEY)
# PAPERCLIP_BOARD_API_KEY=your-board-api-key

# Future bots (add when SOA-156 completes):
# EARL_DISCORD_TOKEN=
# EARL_CHANNEL_ID=
# EARL_AGENT_ID=

# Optional tuning
CONVERSATION_EXPIRY_MINUTES=30
POLL_INTERVAL_SECONDS=5
POLL_TIMEOUT_SECONDS=300
